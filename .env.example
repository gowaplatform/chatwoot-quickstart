# URL base da instalação do Chatwoot (sem barra no final), ex: https://chat.seudominio.com
CHATWOOT_BASE_URL=https://app.seudominio.com

# Porta em que a aplicação vai escutar
PORT=3000

# Prefixo usado no nome do contato quando ele é criado automaticamente
# (usado apenas se "contact_name" não vier no payload da requisição)
DEFAULT_CONTACT_NAME_PREFIX=WhatsApp
